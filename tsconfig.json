{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "typeRoots": ["../../apps/renderer/node_modules/@types"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
